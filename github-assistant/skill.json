{
  "name": "github-assistant",
  "version": "1.0.0",
  "description": "GitHub 助手 - 仓库管理、Issue/PR 处理、代码审查",
  "author": "yanjiayi-bd (cloned from clawhub top10)",
  "license": "MIT",
  "type": "skill",
  "tags": ["github", "git", "devops", "code"],
  "entry": {
    "prompt": "prompt.md"
  },
  "inputs": {
    "action": {
      "type": "string",
      "description": "操作类型: repo | issue | pr | review",
      "required": true,
      "enum": ["repo", "issue", "pr", "review"]
    },
    "repo": {
      "type": "string",
      "description": "仓库地址 (owner/repo)",
      "required": true
    },
    "data": {
      "type": "object",
      "description": "操作数据",
      "required": false
    }
  },
  "outputs": {
    "result": {
      "type": "object",
      "description": "操作结果"
    }
  }
}
