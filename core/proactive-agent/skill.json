{
  "name": "proactive-agent",
  "version": "1.0.0",
  "description": "将 AI 智能体从任务执行者转变为能预见需求、持续优化的主动伙伴",
  "author": "yanjiayi-bd (cloned from clawhub top10)",
  "license": "MIT",
  "type": "skill",
  "tags": ["proactive", "agent", "automation", "ai"],
  "entry": {
    "prompt": "prompt.md"
  },
  "inputs": {
    "mode": {
