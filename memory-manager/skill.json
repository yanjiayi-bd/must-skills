{
  "name": "memory-manager",
  "version": "1.0.0",
  "description": "记忆管理器 - 智能记忆存储、检索、关联和压缩",
  "author": "yanjiayi-bd (cloned from clawhub top10)",
  "license": "MIT",
  "type": "skill",
  "tags": ["memory", "storage", "retrieval", "context"],
  "entry": {
    "prompt": "prompt.md"
  },
  "inputs": {
    "action": {
      "type": "string",
      "description": "操作: store | retrieve | associate | compress",
      "required": true
    },
    "key": {
      "type": "string",
      "description": "记忆键或查询",
      "required": true
    },
    "data": {
      "type": "any",
      "description": "存储的数据",
      "required": false
    }
  },
  "outputs": {
    "result": {
      "type": "any",
      "description": "操作结果"
    }
  }
}
